# Keycloak OIDC Configuration
KEYCLOAK_CLIENT_ID=mimir-chat
KEYCLOAK_CLIENT_SECRET=change-me-to-keycloak-client-secret
KEYCLOAK_ISSUER=http://localhost:8080/realms/mimir

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-to-a-random-secret-string

# Mimir API Configuration
OPENAI_API_HOST=http://localhost:5001

# Default Model (should match a model available in LM Studio via LiteLLM)
DEFAULT_MODEL=qwen2.5-coder-32b-instruct

# Default System Prompt
NEXT_PUBLIC_DEFAULT_SYSTEM_PROMPT=You are nem.Mimir, a helpful AI assistant. Follow the user's instructions carefully.
