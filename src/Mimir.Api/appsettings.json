{
  "Jwt": {
    "Authority": "http://mimir-keycloak:8080/realms/mimir",
    "Audience": "mimir-api",
    "RequireHttpsMetadata": false
  },
  "LiteLlm": {
    "BaseUrl": "http://mimir-litellm:4000",
    "ApiKey": "",
    "TimeoutSeconds": 120
  },
  "Database": {
    "ConnectionString": "Host=mimir-db;Port=5432;Database=mimir;Username=mimir;Password=${DB_PASSWORD}"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=mimir-db;Port=5432;Database=mimir;Username=mimir;Password=${DB_PASSWORD}"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "Sanitization": {
    "MaxMessageLength": 10000,
    "LogSuspiciousPatterns": true,
    "StripHtmlTags": true
  },
  "RabbitMQ": {
    "ConnectionString": "amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@localhost:5672"
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:3000"]
  },
  "AllowedHosts": "*"
}
