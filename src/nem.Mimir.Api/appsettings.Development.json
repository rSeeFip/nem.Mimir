{
  "MimirApiOptions": {
    "StandaloneMode": true
  },
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/mimir",
    "Audience": "mimir-api",
    "RequireHttpsMetadata": false
  },
  "LiteLlm": {
    "BaseUrl": "http://172.18.0.1:14000",
    "ApiKey": "",
    "TimeoutSeconds": 120
  },
  "Database": {
    "ConnectionString": "Host=nem-postgres;Port=5432;Database=mimir;Username=mimir;Password=mimir_dev_password"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=nem-postgres;Port=5432;Database=mimir;Username=mimir;Password=mimir_dev_password"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.AspNetCore": "Information",
        "Microsoft.EntityFrameworkCore": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "Sanitization": {
    "MaxMessageLength": 10000,
    "LogSuspiciousPatterns": true,
    "StripHtmlTags": true
  },
  "RabbitMQ": {
    "ConnectionString": "amqp://guest:guest@nem-rabbitmq:5672"
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:3000", "http://localhost:3100"]
  }
}
